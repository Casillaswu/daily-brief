<style>
  :root {
    --ink: #1f1d1a; --ink-2: #4a4742; --ink-3: #8a857d;
    --paper: #ffffff; --paper-2: #f7f5f1;
    --rule: #d9d4cb; --hi: #fff3a6;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #f0eee9; color: var(--ink);
    font-family: Arial, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", "PingFang TC", "Microsoft JhengHei", sans-serif;
    -webkit-text-size-adjust: 100%; }
  .page { max-width: 880px; margin: 0 auto; padding: 36px 28px;
    background: var(--paper); min-height: 100vh; }
  .kicker { font-size: 11px; letter-spacing: .22em; color: var(--ink-3);
    font-weight: 700; text-transform: uppercase; margin-bottom: 4px; }
  h1 { margin: 0 0 6px; font-size: 24px; font-weight: 800; line-height: 1.2; }
  .sub { font-size: 13px; color: var(--ink-2); margin-bottom: 28px;
    padding-bottom: 14px; border-bottom: 2px solid var(--ink); }
  ul { list-style: none; padding: 0; margin: 0; }
  .entry { border-bottom: 1px solid var(--rule); position: relative; }
  .entry-main { display: block; padding: 18px 60px 18px 8px; text-decoration: none;
    color: var(--ink); transition: background .12s; }
  .entry-main:hover { background: var(--paper-2); }
  .entry.empty { padding: 18px 8px; color: var(--ink-3); font-size: 13px; }
  .entry-en {
    position: absolute; top: 50%; right: 14px; transform: translateY(-50%);
    font-size: 11px; font-weight: 700; letter-spacing: .05em;
    padding: 5px 12px; border: 1px solid var(--rule); border-radius: 999px;
    background: var(--paper); color: var(--ink-2); text-decoration: none;
    transition: all .15s ease;
  }
  .entry-en:hover {
    background: var(--ink); color: #fff; border-color: transparent;
    transform: translateY(-50%) scale(1.05);
  }
  .row1 { display: flex; align-items: baseline; gap: 14px; margin-bottom: 6px;
    flex-wrap: wrap; }
  .week { font-family: ui-monospace, Menlo, monospace; font-size: 13px;
    font-weight: 700; background: var(--hi); padding: 1px 8px; border-radius: 2px;
    color: var(--ink); }
  .date { font-size: 12px; color: var(--ink-3); letter-spacing: .04em; }
  .desc { font-size: 14px; color: var(--ink-2); line-height: 1.55; }
  footer { margin-top: 40px; padding-top: 16px; border-top: 1px solid var(--rule);
    font-size: 11px; color: var(--ink-3); text-align: center; letter-spacing: .04em; }
  @media (max-width: 600px) {
    .page { padding: 24px 18px; }
    h1 { font-size: 20px; }
    .entry-main { padding: 18px 56px 18px 8px; }
    .entry-en { right: 10px; padding: 4px 10px; font-size: 10px; }
  }
</style>
</head>
